@{
}

<div class="row mt-4">
    <div class="col-sm-8 offset-sm-2">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0" id="title">New Sale</h2>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-success" id="btnSaveSale">Save</button>
                <a class="btn btn-warning" href="/Sale/Index">Back</a>
            </div>
        </div>
        <form id="saleForm">
            <div class="input-group mb-3">
                <span class="input-group-text">Customer Name</span>
                <input type="text" class="form-control" id="customerName" name="customerName">
            </div>

            <hr />
            <div class="input-group mb-3">
                <span class="input-group-text">Product Name</span>
                <input type="text" class="form-control" id="productName">
            </div>

            <div class="d-flex gap-2">
                <div class="input-group mb-3">
                    <span class="input-group-text">Price</span>
                    <input type="number" class="form-control" id="price">
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text">Quantity</span>
                    <input type="number" class="form-control" id="quantity">
                </div>
            </div>

            <div class="d-grid mb-3">
                <button type="button" class="btn btn-primary" id="btnAddProduct">Add Product</button>
            </div>

            <table class="table" id="tbProducts">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Sub Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </form>
    </div>
</div>

@section Scripts{

    <script>
        const myLoader = new AvalynxLoader("#saleForm");

        let products = [];

        let saleId = 0;

        window.addEventListener("load", () =>{
            const urlParams = new URLSearchParams(window.location.search)
            if(urlParams.has("saleId")){
                title.textContent = "Edit Sale";
                saleId = urlParams.get("saleId");
                showSale();
            }
        })

       async  function showSale(){
            myLoader.load = true;
             const response = await fetch(`/Sale/Get?SaleId=${saleId}` ,{
                 method:'GET'
             })

             const result = await response.json();

             if(response.ok){
                 customerName.value = result.customerName;
                 products = result.saleDetails.map(p => ({
                    productName : p.productName,
                    price : p.price,
                    quantity : p.quantity,
                    subtotal : p.price * p.quantity
                 }))

                 updateProductTable();
             }

             myLoader.load = false;
        }


        document.getElementById("btnAddProduct").addEventListener("click",() =>{


            const productName = document.getElementById("productName").value;
                const price = parseFloat(document.getElementById("price").value);
            const quantity = parseInt(document.getElementById("quantity").value);

             if (!productName || !price || !quantity) {
                  Swal.fire({
                      text: "Please fill all product fields",
                      icon: "error", timer: 1600,position:"top"
                    });
                return;
            }

             const subtotal = price * quantity;

              const product = {
                productName: productName,
                price: price,
                quantity: quantity,
                subtotal: subtotal
            };

            products.push(product);

            updateProductTable()

            document.getElementById("productName").value = "";
            document.getElementById("price").value = "";
            document.getElementById("quantity").value = "";

    
        })

        function updateProductTable(){
            const tbody = document.querySelector("#tbProducts tbody");
            tbody.innerHTML = "";

            products.forEach((product,index) => {
                const row = tbody.insertRow();

                row.insertCell(0).textContent = product.productName;
                row.insertCell(1).textContent = product.price.toFixed(2);
                row.insertCell(2).textContent = product.quantity;
                row.insertCell(3).textContent = product.subtotal.toFixed(2);

                const deleteCell = row.insertCell(4);
                const deleteBtn = document.createElement("button");
                deleteBtn.textContent = "Delete";
                deleteBtn.className = "btn btn-danger btn-sm";
                deleteBtn.onclick = () => removeProduct(index);
                deleteCell.appendChild(deleteBtn);
            })
        }

        function removeProduct(index){
            products.splice(index,1);
            updateProductTable();
        }

        document.getElementById("btnSaveSale").addEventListener("click",async () => {
         const customerName = document.getElementById("customerName").value;
           if (!customerName) {
                Swal.fire({
                  text: "Please enter customer name",
                  icon: "error", timer: 1600,position:"top"
                });
                return;
            }

              if (products.length === 0) {
                Swal.fire({
                  text: "Please add at least one product",
                  icon: "error", timer: 1600,position:"top"
                });
                return;
            }

            myLoader.load=true;
        
             const saleData = {

                 saleId: saleId == 0 ? 0: saleId,

                 customerName : customerName,
                 totalAmount : products.reduce((sum,product) => sum + product.subtotal,0),
                 saleDetails : products.map(p => ({
                     productName :p.productName,
                     price :p.price,
                     quantity :p.quantity,
                 }))
             }

             const urlAction = saleId == 0 ? '/Sale/Create': '/Sale/Edit';
             const methodAction = saleId == 0 ? 'POST': 'PUT';

             const response = await fetch(urlAction,{
                 method:methodAction,
                 headers:{ 'Content-type':'application/json'},
                 body: JSON.stringify(saleData)
             })

             const result = await response.json();

             myLoader.load = false;

             if(response.ok){

                 if(saleId == 0){
                     Swal.fire({ text: result.message,  icon: "success", timer: 1500,position:"top"});
                 }else{
                     Swal.fire({ text: result.message,  icon: "success", timer: 1500,position:"top",timerProgressBar: true})
                     .then((result) => {
                         window.location.href = "/Sale/Index"
                     });
                 }


                 
                 document.getElementById("customerName").value = "";
                 products = [];
                 updateProductTable();
             }else{
                    Swal.fire({ text: result.message,  icon: "error", timer: 1500,position:"top"});
             }

        })

    </script>
}
