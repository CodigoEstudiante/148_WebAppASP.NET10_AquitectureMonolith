<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyWebStore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="~/lib/sweetalert2/dist/sweetalert2.min.css" rel="stylesheet" />
    <link href="~/lib/datatablejs/datatables.net-dt/css/datatables.datatables.min.css" rel="stylesheet" />
    <link href="~/lib/datatablejs/datatables.net-responsive-dt/css/responsive.datatables.min.css" rel="stylesheet" />
    <link href="~/lib/datatablejs/datatables.net-buttons-dt/css/buttons.datatables.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/MyWebStore.styles.css" asp-append-version="true" />

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MyWebStore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Sale" asp-action="Index">Sales</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MyWebStore - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/avalynx-loader/dist/js/avalynx-loader.min.js"></script>
    <script src="~/lib/sweetalert2/dist/sweetalert2.min.js"></script>

    <script src="~/lib/datatablejs/datatables.net/js/datatables.min.js"></script>
    <script src="~/lib/datatablejs/datatables.net-responsive/js/datatables.responsive.min.js"></script>
    <script src="~/lib/datatablejs/datatables.net-responsive-dt/js/responsive.datatables.min.js"></script>
    <script src="~/lib/datatablejs/datatables.net-buttons/js/datatables.buttons.min.js"></script>
    <script src="~/lib/datatablejs/datatables.net-buttons/js/buttons.html5.min.js"></script>
    <script src="~/lib/datatablejs/datatables.net-buttons/js/buttons.print.min.js"></script>
    <script src="~/lib/datatablejs/datatables.net-buttons-dt/js/buttons.datatables.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
